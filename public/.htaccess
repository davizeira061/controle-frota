<IfModule mod_rewrite.c>
    RewriteEngine On

    # Remover trailing slash (opcional)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [L,R=301]

    # Redirecionar todos os requests para index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Segurança adicional
<FilesMatch "\.env$">
    Require all denied
</FilesMatch>

<FilesMatch "\.sql$">
    Require all denied
</FilesMatch>

# Cache headers
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType application/json "now"
    ExpiresByType text/html "now"
</IfModule>
