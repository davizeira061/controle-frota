# Controle Frota SaaS - Arquivo de Configuração

# BANCO DE DADOS
DB_HOST=localhost
DB_NAME=controle_frota
DB_USER=root
DB_PASS=

# APLICAÇÃO
DEBUG=true
APP_ENV=development
APP_NAME="Controle Frota"

# SESSÃO
SESSION_LIFETIME=2592000
SESSION_SECURE=false

# CORS (se necessrio)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1

# EMAIL (para notificações futuras)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# API
API_VERSION=v1

# TIMEZONE
TIMEZONE=America/Sao_Paulo
